/pgas_ideas.csv

# Respaldos del CSV
*.backup*.csv

# Fuentes de referencia (insumos, no parte del pipeline)
WhatsApp Image*.jpeg
candidate-*.png
candidate-*.webp

# Sistema
.DS_Store
