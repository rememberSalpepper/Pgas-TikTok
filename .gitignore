# Secretos (token de Telegram, etc.) — NUNCA subir al repo
.env
pgas-generator/.env

# Dependencias
node_modules/
pgas-generator/node_modules/

# Imágenes generadas (se regeneran en cada máquina/VPS)
pgas-generator/dist/*
!pgas-generator/dist/.gitkeep

# CSV vivo: lo maneja el programa en cada máquina (el VPS tiene el suyo).
